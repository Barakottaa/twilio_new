# Environment Variables Template
# Copy this file to .env.local for local development or env.production for Docker

# Database Configuration (SQLite - Default)
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./database.sqlite

# Twilio Configuration (Required for WhatsApp functionality)
# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_API_KEY=your_api_key_here
TWILIO_API_SECRET=your_api_secret_here
TWILIO_PHONE_NUMBER=your_phone_number_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Application Configuration
NODE_ENV=development
NEXTAUTH_SECRET=your-super-secret-key-here-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Server Configuration
PORT=3000
HOSTNAME=0.0.0.0

# Optional: Analytics and Monitoring
# VERCEL_ANALYTICS_ID=your-analytics-id

# Optional: Oracle Database (if using Oracle instead of SQLite)
# DATABASE_TYPE=oracle
# ORACLE_USER=crm
# ORACLE_PASSWORD=crm
# ORACLE_CONNECT_STRING=oracle-db:1521/XE

# Optional: Logging
LOG_LEVEL=info
